# ===========================================
# Azure MCP Agent - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.

# --- Microsoft Bot Framework (Teams Integration) ---
MicrosoftAppId=
MicrosoftAppPassword=

# --- Azure Cosmos DB (Agent Memory) ---
COSMOS_ENDPOINT=https://your-cosmosdb.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key

# --- Azure Application Insights (Telemetry) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://xxx.in.applicationinsights.azure.com/

# --- Azure Credentials (for MCP Servers to call Azure APIs) ---
# When using DefaultAzureCredential, set these for Service Principal auth:
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# --- LLM Provider (pick ONE — used for intent classification) ---
# Option 1: Groq (FREE — sign up at https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Option 2: Google Gemini (FREE — get key at https://ai.google.dev)
# GOOGLE_API_KEY=your_google_api_key_here

# Option 3: Azure OpenAI (enterprise — requires approval)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# AZURE_OPENAI_DEPLOYMENT=gpt-4
# AZURE_OPENAI_API_VERSION=2024-02-01

# If none of the above are set, the system uses keyword-based classification (no LLM needed).

# --- MCP Server URLs (auto-configured in K8s via ConfigMap) ---
# Override these only for local development:
COST_MCP_URL=http://localhost:3000
POLICY_MCP_URL=http://localhost:3001
GOVERNANCE_MCP_URL=http://localhost:3002
SECURITY_MCP_URL=http://localhost:3003
AZURE_TOOLS_MCP_URL=http://localhost:3004

# --- Application Port ---
PORT=8080
